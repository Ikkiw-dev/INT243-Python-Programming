    "#Exercise 2 -> List manipulator\n",
    "def list_manipulation(lst, command, value=None, index=None):\n",
    "    default_command = ['add','remove','modify']\n",
    "    command = str(command)\n",
    "\n",
    "    if command not in default_command:\n",
    "        return \"This command does not exist.\"\n",
    "    elif command == 'add':\n",
    "        lst.append(value)\n",
    "    elif command == 'remove':\n",
    "        lst.pop() #or use indexing instead (index -1) -> lst = lst[:-1]\n",
    "    elif command == 'modify':\n",
    "        lst[index] = value\n",
    "\n",
    "    return lst\n",
    "\n",
    "list_manipulation([2,3,4,5,6], 'modify', 7,1)\n",
    "    "
